# Database
DATABASE_URL=postgresql+asyncpg://afas:afas_secret@db:5432/afas
POSTGRES_USER=afas
POSTGRES_PASSWORD=afas_secret
POSTGRES_DB=afas

# Redis
REDIS_URL=redis://redis:6379/0

# Security
SECRET_KEY=your_secret_key_here_change_in_production
ED25519_PRIVATE_KEY=your_base64_encoded_ed25519_private_key

# JWT Authentication
# JWT_SECRET_KEY defaults to SECRET_KEY if not set
# JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Google OAuth
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add authorized redirect URI: https://your-domain.com/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=https://afasx.my-ai.tech/auth/google/callback
FRONTEND_URL=https://afasx.my-ai.tech

# API Settings
API_HOST=0.0.0.0
API_PORT=44638
DEBUG=false

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Fingerprinting
FINGERPRINT_VERSION=1.0.0

# Ethereum/Blockchain (Sepolia Testnet)
# 1. Sign up at https://dashboard.alchemy.com
# 2. Create a new app, select "Ethereum" and "Sepolia" network
# 3. Copy your API key and paste below
ALCHEMY_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
ETHEREUM_PRIVATE_KEY=your_wallet_private_key_hex
ETHEREUM_NETWORK=sepolia
